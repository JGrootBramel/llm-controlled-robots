<launch>
  <!-- On-demand blue cube detector/grasper -->
  <arg name="stable_hits" default="3" />
  <arg name="depth_min" default="0.10" />
  <arg name="depth_max" default="2.50" />
  <!-- Area threshold: ignore tiny noisy blobs -->
  <arg name="min_area_px" default="200" />
  <arg name="base_frame" default="base_link" />
  <!-- red or blue (red often better in blue-tinted rooms) -->
  <arg name="target_color" default="red" />

  <node pkg="limo_rosa_bridge" type="pick_cube_blue_node.py" name="blue_cube_grasper" output="screen">
    <param name="stable_hits" value="$(arg stable_hits)" />
    <param name="depth_min" value="$(arg depth_min)" />
    <param name="depth_max" value="$(arg depth_max)" />
    <param name="min_area_px" value="$(arg min_area_px)" />
    <param name="base_frame" value="$(arg base_frame)" />
    <param name="target_color" value="$(arg target_color)" />
  </node>
</launch>
